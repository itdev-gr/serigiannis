# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (migration/admin scripts). Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
# Absolute site URL for canonical/sitemap/OG (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: activates office email notifications on new leads (via Resend). Recipient is the
# dashboard's «Email» setting. Leave unset to disable — the app works fine without it.
RESEND_API_KEY=
# Optional: verified Resend sender, e.g. "Sergiani Travel <no-reply@sergianitravel.gr>".
RESEND_FROM=
